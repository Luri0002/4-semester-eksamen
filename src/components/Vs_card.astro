---
const { image, heading, color = "secondary", olives = [] } = Astro.props;
import { Image } from "astro:assets";
import Heading from "../components/Heading.astro";
---

<div class="flex flex-col items-center gap-10">
  <Image src={image} alt={`${heading} bottle`} loading="lazy"/>

  <Heading htmlheading="h4" size="small" font="display" color={color}>
    {heading}
  </Heading>

  {
    olives.map((olive, index) => (
      <Image src={olive} alt="" loading="lazy" />
    ))
  }
</div>