---
// Henter parametrene fra Astro.props
const { variant = "primary" } = Astro.props;

// Grundlæggende styling for knappen
// Vi bruger 'cursor-none' for at skjule den rigtige mus, og 'group' til at styre hover på elementerne indeni
const buttonStyling = "relative overflow-hidden font-heading text-lg md:text-xl lg:text-2xl border-1 md:border-2 rounded-full px-4 pt-1.5 pb-2 md:px-5 md:pt-1.5 md:pb-2.5 cursor-none group";

const variantClasses = {
  primary: "border-dark-700 bg-secondary-500 text-dark-600 hover:text-secondary-500 hover:border-secondary-500 hover:bg-dark-600 transition-colors duration-600",
  secondary: "border-light bg-dark text-primary-500 hover:text-dark hover:border-dark hover:bg-primary-500 transition-colors duration-600",
};
---

<button class:list={[buttonStyling, variantClasses[variant]]} onmousemove="this.style.setProperty('--x', event.offsetX + 'px'); this.style.setProperty('--y', event.offsetY + 'px')">
  <span class="relative z-20 pointer-events-none">
    <slot />
  </span>

  <div class="oliven-cursor pointer-events-none absolute left-0 top-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="transform: translate(calc(var(--x) - 50%), calc(var(--y) - 50%));"></div>
</button>

<style>
  button {
    /* 'isolate' sikrer at z-index 10 og 20 kun gælder internt i knappen */
    isolation: isolate;
  }

  .oliven-cursor {
    width: 40px; /* Juster størrelsen på din oliven her */
    height: 40px;
    z-index: 10; /* Højere end knappens baggrund, men lavere end teksten (z-20) */
    background-image: url("/oliven.svg"); /* Sørg for at stien passer til din public-mappe */
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    /* transition: transform 0.05s linear; -- kan tilføjes hvis den skal føles "blød", men uden er den mest præcis */
    will-change: transform;
  }
</style>
