---
// Henter parametrene fra Astro.props
const { htmlheading = "h1", size = "medium", font = "heading", color = "dark600", stylingclasses = "" } = Astro.props;
const Htmlheading = htmlheading;

//Definer den styling (Tailwind classes), der gør sig gældende for de forskellige størrelser.
const sizeClasses = {
  // h1
  xlarge: "text-4xl md:text-6xl lg:text-8xl pb-6",

  // h2
  large: "text-3xl md:text-5xl lg:text-7xl pb-5",

  // h3
  medium: "text-2xl md:text-4xl lg:text-6xl pb-4",

  // h4
  small: "text-xl md:text-2xl lg:text-3xl pb-3",
};

//Definer den styling (Tailwind classes), der gør sig gældende for de forskellige skrifttyper.
const fontClasses = {
  heading: "font-heading",
  display: "font-display",
};

//Definer den styling (Tailwind classes), der gør sig gældende for de forskellige skrifttyper.
const colorClasses = {
  primary: "text-primary-500",
  primary200: "text-primary-200",
  secondary: "text-secondary-500",
  secondary400: "text-secondary-400",
  accent: "text-accent-500",
  accent700: "text-accent-700",
  dark600: "text-dark-600",
  dark900: "text-dark-900",
  light: "text-light-500",
};
---

<Htmlheading class:list={[stylingclasses, sizeClasses[size], fontClasses[font], colorClasses[color]]}><slot /></Htmlheading>
