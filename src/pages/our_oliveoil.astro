---
import MainLayout from "../layouts/MainLayout.astro";
import Heading from "../components/Heading.astro";
import Text from "../components/Text.astro";
import Button from "../components/Button.astro";
import { Image } from "astro:assets";
import ouroliveoil_herobillede from "../assets/images/ouroliveoil_herobillede.webp";
import full_olive from "../assets/images/oliven.svg";
import half_olive from "../assets/images/half_olive.svg";
import stroke_olive from "../assets/images/stroke_olive.svg";
import bottle from "../assets/images/oliveoil_bottle.webp";
import tin from "../assets/images/olive-oil-tin.png";
import VsCard from "../components/Vs_card.astro";
import FaqSection from "../components/FaqSection.astro";
import hero_billede1 from "../assets/images/hero_billede1.webp";
import from_tree_to_bottle2 from "../assets/images/from_tree_to_bottle2.webp";
import from_tree_to_bottle3 from "../assets/images/from_tree_to_bottle3.webp";
import from_tree_to_bottle4 from "../assets/images/from_tree_to_bottle4.webp";
import from_tree_to_bottle5 from "../assets/images/from_tree_to_bottle5.webp";
import ProductSection from "../components/ProductSection.astro";
---

<MainLayout title="Our Olive Oil" description="On this page you can read about Abdeljalil Olive Oil and the production process">
<main class="pt-35 lg:pt-50">
<!-- first section start -->
<section class="grid grid-cols-6 px-5 md:px-10 md:grid-cols-12"> 
<!-- headings start -->
<div class="col-start-1 col-span-6 md:col-span-10 lg:col-span-9 gap-2.5"> 
<Heading htmlheading="h1" size="small" font="display">Our Olive Oil</Heading>
<Heading htmlheading="h2" size="medium" font="heading">Our Extra Virgin Olive Oil is a testament to quality, with this year's harvest aiming for an acidity level of less than 0.4% </Heading>
</div>
<!-- headings slut -->

<!-- text-picture start -->
<div class="py-5 md:pt-10 md:pb-20 col-start-1 col-span-6 md:col-start-2 md:col-span-5 lg:col-start-4 lg:col-span-4"> 
<Text stylingclasses="mb-5 lg:mb-10">This estimation is based on our extensive experience in producing olive oil from our family's farm and distributing it to family and friends inside and outside Morocco. The consistency of our process and the health of our olive trees contribute to this result. Our previous harvests have undergone rigorous testing, confirming our ability to  produce an oil that far exceeds the strict criteria for extra virgin  which requires an acidity level of 0.8% or less.</Text>
<Image src={ouroliveoil_herobillede} alt="Picture of an olive branch" class="" />
</div>
<!-- text-picture slut -->

<!-- text-button start -->
<div class="pb-10 col-start-1 col-span-6 md:col-start-8 md:col-span-5 lg:col-start-9 lg:col-span-4 md:self-end md:mb-14">
<Text stylingclasses="mb-5 md:mb-10">This low acidity level is a key indicator of olive oil quality. It measures the amount of free fatty acids present in the oil, expressed as a percentage of oleic acid. Contrary to its name, this acidity does not affect the oil's taste. A lower acidity indicates that the oil was produced from healthy, undamaged olives with minimal processing time. When the olive fruits are damaged or processing is delayed, fatty acids are released, which increases the acidity. 
Our careful production process ensures a low acidity, reflecting our commitment to quality.</Text>
<Button href = "/buy">Shop the Harvest</Button>
</div>
<!-- text-button slut -->
</section>
<!-- first section slut -->
    
<!-- comparison section start -->
<section class="bg-secondary-900 py-10 lg:py-20 overflow-hidden">

<!-- overskrifter start -->
<div class="px-5 lg:px-10 mb-5 lg:mb-10"> 
<Heading htmlheading="h2" size="small" font="display" color="secondary">Not all olive oil is the same</Heading>
<Heading htmlheading="h3" size="medium" color="secondary">Abdeljalil vs. others</Heading>
</div>
<!-- overskrifter slut -->

<!-- mobile + desktop comparison wrapper -->
<div class="relative px-5 lg:px-10">

<!-- scroll area -->
<div class="overflow-x-auto lg:overflow-visible">

<!-- grid -->
<div class="grid grid-cols-[160px_repeat(3,220px)] lg:grid-cols-4 items-center gap-10 min-w-max lg:min-w-0">

<!-- labels start -->
<div class="sticky left-0 z-30 self-stretch w-45 bg-secondary-900 pr-6 lg:static lg:w-auto lg:bg-transparent lg:z-auto">

<!-- labels content -->
<div class="flex flex-col gap-14 mt-80 lg:mt-90 relative z-10">
    <Text teksttype="manchet" font="heading" color="secondary">Extra virgin</Text>
    <Text teksttype="manchet" font="heading" color="secondary">Ethically sourced</Text>
    <Text teksttype="manchet" font="heading" color="secondary">Harvesting tradition</Text>
    <Text teksttype="manchet" font="heading" color="secondary">Regenerative ecosystem</Text>
</div>

</div>
<!-- labels slut -->

<!-- vs cards start -->
<VsCard image={bottle} heading="supermarket olive oil" olives={[half_olive, stroke_olive, stroke_olive, stroke_olive]}/>

<div class="bg-primary-500 rounded-3xl pb-8">
<VsCard
  image={tin}
  heading="Abdeljalil olive oil"
  color="dark600"
  olives={[full_olive, full_olive, full_olive, full_olive]}
/>
</div>

<VsCard image={bottle} heading="Luxury olive oil" olives={[full_olive, half_olive, half_olive, stroke_olive]}/>
<!-- vs cards slut -->

</div>
</div>
</div>

</section>
<!-- comparison section slut -->

<!-- from tree to bottle section start -->
<section class="relative z-20 bg-primary-500 px-5 py-10 lg:px-10 lg:pt-10 lg:pb-0">

  <!-- sticky heading -->
  <div class="pt-5 lg:pb-10 sticky top-0 lg:top-64 z-30 flex justify-center text-center bg-primary-500 lg:bg-transparent">
    <Heading htmlheading="h2" size="large" font="display">From tree <br /> to bottle</Heading>
  </div>

<!-- scroll content -->
<div class="relative z-10 grid grid-cols-6 lg:gap-x-5 lg:grid-cols-12 lg:grid-rows-[repeat(11,215px)]">

  <!-- item 1 start-->
    <div class="col-start-1 col-span-5 mb-10 lg:mb-0 lg:col-span-4 lg:row-start-1">

    <!-- div med heading + text start -->
    <div class="gap-2.5 lg:gap-5"> 
    <Heading htmlheading="h3" size="small" font="display">Step 1:<br /> Harvest</Heading>
    <Text>We begin harvesting in late October and early November, while the olives are still green and early in their ripening cycle.</Text>
    <Text stylingclasses="mt-2.5 lg:mt-5">Although this produces a lower yield, it results in a higher concentration of polyphenols, giving the oil its distinctive peppery and bitter character. </Text>
    </div>
    <!-- div med heading + text slut -->
      <Image src={hero_billede1} alt="Olive trees grove during harvesting" class="mt-5 lg:mt-10"/>
    </div>
  <!-- item 1 slut-->
  
  <!-- item 2 start-->
    <div class="col-start-3 col-span-4 lg:col-start-10 lg:col-span-3 lg:row-start-2 mb-10 lg:mb-0">

    <!-- div med heading + text start -->
    <div class="gap-2.5 lg:gap-5"> 
    <Heading htmlheading="h3" size="small" font="display">Step 2:<br /> Journey</Heading>
    <Text>All olives are hand-picked and transported by truck to our processing partner in Sidi Bou Othmane, located just two hours from our farm. This close distance allows the olives to be processed within 24 hours, preserving freshness and quality. </Text>
    </div>
    <!-- div med heading + text slut -->
      <Image src={from_tree_to_bottle2} alt="Abdeljalil's family on the olive grove" class="mt-5 lg:mt-10"/>
    </div>
  <!-- item 2 slut-->
  
<!-- item 3 start-->
<div class="col-start-1 col-span-4 mb-10 lg:mb-0 lg:row-start-5 lg:col-start-2 lg:col-span-7">
  <div class="lg:flex lg:flex-row lg:items-end">
    <!-- div med heading + text start -->
    <div class="gap-2.5 lg:gap-5 lg:mr-5"> 
    <Heading htmlheading="h3" size="small" font="display">Step 3:<br /> Cleaning & crushing</Heading>
    <Text>At the mill, the olives are added to a processing machine that can handle up to ten tonnes at a time. Leaves and branches are removed, and the olives are washed with cold water to eliminate dirt.</Text>
    <Text stylingclasses="mt-2.5 lg:mt-5">The cleaned olives are then crushed and kneaded for at least 40 minutes. Processing in small batches helps preserve aroma, antioxidants, and nutrients, creating a paste made of oil, water, and olive pulp. </Text>
  </div>
    <!-- div med heading + text slut -->
      <Image src={from_tree_to_bottle3} alt="Olives cleaning and crushing process" class="mt-5"/>
  </div>
</div>
<!-- item 3 slut-->

<!-- item 4 start-->
  <div class="col-start-2 col-span-5 lg:col-start-9 lg:col-span-4 lg:row-start-7 mb-10 lg:mb-0">

    <!-- div med heading + text start -->
    <div class="gap-2.5 lg:gap-5"> 
    <Heading htmlheading="h3" size="small" font="display">Step 4:<br />Oil Extraction</Heading>
    <Text>The oil is extracted using a fully mechanical process without chemicals, heat, or solvents. The olive paste is spun in a high-speed horizontal centrifuge, which separates solids, water, and oil based on density.</Text>
    <Text stylingclasses="mt-2.5 lg:mt-5">A second vertical centrifuge further refines the oil by removing remaining water and fine particles, resulting in pure extra virgin olive oil.</Text>
  </div>
    <!-- div med heading + text slut -->
      <Image src={from_tree_to_bottle4} alt="Abdeljalil's family on the olive grove" class="mt-5 lg:mt-10"/>
  </div>
<!-- item 4 slut-->

<!-- item 5 start-->
<div class="col-start-1 col-span-4 lg:col-span-6 lg:row-start-9 lg:col-start-1">
  <div class="lg:flex lg:flex-row lg:items-end">
    <!-- div med heading + text start -->
    <div class="gap-2.5 lg:gap-5 lg:order-2"> 
    <Heading htmlheading="h3" size="small" font="display">Step 5:<br /> Storage & Bottling</Heading>
    <Text>The fresh oil is stored in stainless steel vats for around four days, allowing natural sediment to settle before bottling and delivery.</Text>
  </div>
    <!-- div med heading + text slut -->
      <Image src={from_tree_to_bottle5} alt="Bottling process of the olive oil" class="lg:order-1 mt-5 lg:mt-0 lg:mr-5"/>
  </div>
</div>
<!-- item 5 slut-->
    

</div>
</section>
<!-- from tree to bottle section slut -->

<!-- FAQ section start -->
<FaqSection />
<!-- FAQ section slut -->

<!-- Product section start -->
<section> 
      <ProductSection imageFirst={true} cardTitle="Abdeljalil Olive Oil" cardText="Crafted from 100% Haouzia olives, cultivated on family-owned farms, our oil offers an intense green fruitiness with distinct notes of artichoke, green almond, and fresh tomato with a peppery finish." buttonHref="/our_oliveoil" buttonText="More about our olive oil" />
</section>
<!-- Product section slut -->

</main>
</MainLayout>
