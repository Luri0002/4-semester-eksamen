---
import MainLayout from "../layouts/MainLayout.astro";
import Heading from "../components/Heading.astro";
import Text from "../components/Text.astro";
import Button from "../components/Button.astro";
import { Image } from "astro:assets";
import abdeljalil_1 from "../assets/images/abdeljalil_1.webp";
import abdeljalil_2 from "../assets/images/abdeljalil_2.webp";
import abdeljalil_3 from "../assets/images/abdeljalil_3.webp";
import ourwayofcare1 from "../assets/images/our_way_of_care1.webp";
import ourwayofcare2 from "../assets/images/our_way_of_care2.webp";
import ourwayofcare3 from "../assets/images/our_way_of_care3.webp";
import ourwayofcare4 from "../assets/images/our_way_of_care4.webp";
import Abdeljalil from "../assets/images/abdeljalil.webp";
import Anas from "../assets/images/anas.webp";
import Lea from "../assets/images/lea.webp";
import Abdeljalil_logo from "../assets/images/logo.svg";
import Anas_logo from "../assets/images/anas.svg";
import Lea_logo from "../assets/images/lea.svg";
import ProductSection from "../components/ProductSection.astro";
---

<MainLayout title="Explore our farm" description="On this page you can explore our farm and meet Abdeljalil, the face of our craft. Learn about our regenerative approach to farming, our harvest ritual, and how we bring the authentic taste of Morocco from our family tradition to your tables.">
<main class="pt-35 lg:pt-50">

<!-- first section start -->
<section class="relative grid grid-cols-6 px-5 md:px-10 md:grid-cols-12">

<!-- lyd knap start -->
<button
  id="sound-button"
  class="fixed left-5 bottom-5 md:left-10 md:bottom-10 z-40 w-36 md:w-60 transition-opacity duration-300"
  aria-label="Play sound"
>
  <img
    id="sound-button-img"
    src="/images/lydmute_knap.svg"
    alt="muted button that plays sound"
  />
</button>
<!-- lyd knap slut -->

<!-- lydfilen -->
<audio id="farm-audio" src="/sounds/farm_sound.mp3" loop></audio>

<!-- headings start -->
<div class="col-start-1 col-span-6 md:col-span-9 gap-2.5"> 
<Heading htmlheading="h1" size="small" font="display">Explore our farm</Heading>
<Heading htmlheading="h2" size="medium" font="heading">Meet Abdeljalil</Heading>
</div>
<!-- headings slut -->

<!-- text-picture-text start -->
<div class="py-5 md:py-10 col-start-1 col-span-6 md:col-start-3 md:col-span-5 lg:col-start-4 lg:col-span-4"> 
<Text stylingclasses="mb-5 md:mb-10">The story of our olive oil begins with a man: Abdeljalil. Raised with six siblings in the vibrant old town of Marrakesh, he grew up with an insatiable curiosity for the world. That passion led him to become a life science teacher, dedicated to showing how nature evolves and works together. He passed this same spirit to his sons, Marouane and Anas, teaching them to see the world, its people, and its wonders with open minds.</Text>
<Image src={abdeljalil_2} alt="Picture of Abdeljalil that stands between two olive trees" loading="eager" fetchpriority="high"/>
<Text stylingclasses="mt-5 md:mt-10">Abdeljalil spent much of his free time on the family farm, teaching his children to care for their century old Haouzia olive trees. These trees, unique to Marrakesh's Haouz province, thrive only in this land's particular climate, producing olives with an intense, unmistakable flavor.</Text>
</div>
<!-- text-picture-text slut -->

<!-- picture left-sided start-->
<div class="mb-5 md:-mt-25 lg:-mt-30 col-start-3 col-span-4 md:col-start-9 md:col-span-4 lg:col-start-10 lg:col-span-3"> 
<Image src={abdeljalil_3} alt="Picture of Abdeljalil and his sons" loading="lazy"/>
</div>
<!-- picture left-sided slut-->

<!-- last picture start -->
<div class="mb-10 md:-mt-132 col-start-1 col-span-6 md:col-start-9 md:col-span-4"> 
<Image src={abdeljalil_1} alt="Picture of Abdeljalil by an olive oil machine" loading="lazy"/>
</div>
<!-- last picture slut-->

</section> 
<!-- first section slut -->
  
<!-- our way of care section start -->
<section class="relative z-20 bg-secondary-900 px-5 py-10 lg:px-10 lg:pt-10 lg:pb-0">

  <!-- sticky heading -->
  <div class="pt-5 lg:pb-10 sticky top-0 lg:top-64 z-30 flex justify-center text-center bg-secondary-900 lg:bg-transparent">
    <Heading htmlheading="h2" size="large" font="display" color="primary">
      Our way <br /> of care
    </Heading>
  </div>

  <!-- scroll content -->
  <div class="relative z-10 grid grid-cols-6 lg:gap-x-5 lg:grid-cols-12 lg:grid-rows-[repeat(11,215px)]">

    <!-- item 1 start -->
    <div class="col-start-1 col-span-5 mb-10 lg:col-span-4 lg:row-start-1">

      <!-- text -->
      <div class="gap-2.5 lg:gap-5">
        <Heading htmlheading="h3" size="small" font="display" color="primary">
          Our approach is simple
        </Heading>

        <Text color="primary">
          A regenerative ecosystem. No chemicals, just a diverse balance of plants, animals, and olive trees coexisting. It's farming as it was meant to be, alive, sustainable, and deeply respectful of the land.
        </Text>
      </div>

      <!-- image -->
      <Image
        src={ourwayofcare1}
        alt="picture of vegetables found in the olive grove"
        class="mt-5 lg:mt-10"
        loading="lazy"
      />
    </div>
    <!-- item 1 slut -->

    <!-- item 2 start -->
    <div class="col-start-3 col-span-4 lg:col-start-9 lg:col-span-3 lg:row-start-2 mb-10">

      <!-- text -->
      <div class="gap-2.5 lg:gap-5">
        <Heading htmlheading="h3" size="small" font="display" color="primary">
          the harvest ritual
        </Heading>

        <Text color="primary">
          When harvest arrives, it's more than work, it's celebration. Every olive is hand picked under the Moroccan sun and pressed within 24 hours. The first drop of oil each season carries a joy you can taste: fresh, pure, alive.
        </Text>
      </div>

      <!-- image -->
      <Image
        src={ourwayofcare2}
        alt="farmer picking the olives"
        class="mt-5 lg:mt-10"
        loading="lazy"
      />
    </div>
    <!-- item 2 slut -->

    <!-- item 3 start -->
    <div class="col-start-1 col-span-4 mb-10 lg:row-start-5 lg:col-start-2 lg:col-span-7">

      <div class="lg:flex lg:flex-row lg:items-end">

        <!-- text -->
        <div class="gap-2.5 lg:gap-5 lg:mr-5">
          <Heading htmlheading="h3" size="small" font="display" color="primary">
            the face of our craft
          </Heading>

          <Text color="primary">
            This is what sets us apart. For us, quality has a face and it's Abdeljalil's. His legacy of knowledge, care, and passion lives in every bottle we produce.
          </Text>
        </div>

        <!-- image -->
        <Image
          src={ourwayofcare3}
          alt="Abdeljalil holding some kind of fruit"
          class="mt-5"
          loading="lazy"
        />

      </div>
    </div>
    <!-- item 3 slut -->

    <!-- item 4 start -->
    <div class="col-start-2 col-span-5 lg:col-start-9 lg:col-span-4 lg:row-start-8">

      <!-- text -->
      <div class="gap-2.5 lg:gap-5">
        <Heading htmlheading="h3" size="small" font="display" color="primary">
          from family tradition to your tables
        </Heading>

        <Text color="primary">
          What began as a family tradition, sharing oil with friends, has blossomed into a mission: bringing authentic Haouzia olive oil from Marrakesh to tables around the world, without ever losing the purity and heart that define it.
        </Text>
      </div>

      <!-- image -->
      <Image
        src={ourwayofcare4}
        alt="sunset on the olive grove"
        class="mt-5 lg:mt-10"
        loading="lazy"
      />
    </div>
    <!-- item 4 slut -->

  </div>
</section>
<!-- our way of care section slut -->

<!-- Product section start -->
<section> 
      <ProductSection imageFirst={true} cardTitle="Abdeljalil Olive Oil" cardText="Crafted from 100% Haouzia olives, cultivated on family-owned farms, our oil offers an intense green fruitiness with distinct notes of artichoke, green almond, and fresh tomato with a peppery finish." buttonHref="/our_oliveoil" buttonText="More about our olive oil" />
</section>
<!-- Product section slut -->

<!-- Meet the family section start -->
<section class="px-5 pb-10 md:px-10 md:pb-20">
 <div class="bg-secondary-500 rounded-3xl">

  <!-- overskrift start-->
  <Heading htmlheading="h2" size="medium" stylingclasses="px-4 md:px-8 pt-10 pb-10 ">Meet the family</Heading>
  <!-- overskrift slut -->

  <!-- billederne start-->
  <div class="flex flex-col md:flex-row md:flex-wrap justify-between items-center px-4 md:px-8 md:py-10"> 

    <!-- abdeljalil -->
    <div class="relative mb-32 lg:mb-0">
    <Image src={Abdeljalil} alt="Abdeljalil" class="mb-2.5 md:mb-5" loading="lazy"/>
    <Heading htmlheading="h3" size="small" font="display">Abdeljalil</Heading>
    <Image src={Abdeljalil_logo} alt="Abdeljalil drawing" class="absolute top-70 right-5 md:top-70 md:-right-10 -rotate-5" loading="lazy"/>
    </div>

    <!-- anas -->
    <div class="relative mb-20 lg:mb-0">
    <Image src={Anas} alt="Anas" class="mb-2.5 md:mb-5" loading="lazy"/>
    <Heading htmlheading="h3" size="small" font="display">Anas</Heading>
    <Image src={Anas_logo} alt="Anas drawing" class="absolute -top-14 left-2 md:-top-16 -rotate-5" loading="lazy"/>
    </div>

    <!-- lea -->
    <div class="relative mb-10 lg:mb-0">
    <Image src={Lea} alt="Lea" class="mb-2.5 md:mb-5" loading="lazy"/>
    <Heading htmlheading="h3" size="small" font="display">Lea</Heading>
    <Image src={Lea_logo} alt="Lea drawing" class="absolute top-70 right-5 md:top-70 md:-right-10 rotate-5" loading="lazy"/>
    </div>
  
  </div>
  <!-- billederne slut-->

 </div>
</section>

<!-- Meet the family section slut -->
  
 <script>
  // sound button
  const soundButton = document.querySelector("#sound-button");
  const soundButtonImg = document.querySelector("#sound-button-img");
  const audio = document.querySelector("#farm-audio");

  const defaultSvg = "/images/lydmute_knap.svg";
  const hoverSvg = "/images/lydmute_knap_hover.svg";
  const playingSvg = "/images/lydplay_knap.svg";

  let isPlaying = false;

  soundButton?.addEventListener("mouseenter", () => {
    if (!isPlaying && soundButtonImg) {
      soundButtonImg.src = hoverSvg;
    }
  });

  soundButton?.addEventListener("mouseleave", () => {
    if (!isPlaying && soundButtonImg) {
      soundButtonImg.src = defaultSvg;
    }
  });

  soundButton?.addEventListener("click", () => {
  if (!audio || !soundButtonImg) return;

  if (isPlaying) {
    audio.pause();
    audio.currentTime = 0;
    soundButtonImg.src = defaultSvg;
    isPlaying = false;
  } else {
    soundButtonImg.src = playingSvg;
    isPlaying = true;

    audio.play().catch((error) => {
      console.log("Audio kunne ikke afspilles:", error);
    });
  }
});

  // hide before footer
  const footer = document.querySelector("footer");

  if (soundButton && footer) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          soundButton.classList.add("opacity-0", "pointer-events-none");
        } else {
          soundButton.classList.remove("opacity-0", "pointer-events-none");
        }
      },
      {
        threshold: 0.1,
      }
    );

    observer.observe(footer);
  }
</script>

</main>
</MainLayout>

